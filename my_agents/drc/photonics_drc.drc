# KLayout DRC Script - Photonics Design Rules

source($input, $topcell)

# Report setup
report("DRC Violations")

# Check all layers
all_shapes = nil
[1, 2, 5, 10, 20, 21].each do |l|
  [0, 10].each do |d|
    layer = input(l, d)
    next if layer.is_empty?
    all_shapes = all_shapes ? all_shapes + layer : layer
  end
end

if all_shapes.nil?
  puts "ERROR: No shapes found in any layer!"
else
  # Rule 1: Minimum spacing (2.0 µm)
  violations = all_shapes.space(2.0)
  violations.output("RULE1", "Spacing < 2.0 µm")
  
  # Rule 2: Minimum width (0.4 µm)  
  violations = all_shapes.width(0.4)
  violations.output("RULE2", "Width < 0.4 µm")
  
  # Rule 3: Overlaps
  violations = all_shapes.sized(0.001).merged(2)
  violations.output("RULE3", "Overlapping structures")
end
